generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Roles Enum
enum DmanageRole {
  super_admin
  admin
  teacher
  student

  @@map("dmanage_role")
}

enum PlatformType {
  School
  College
  University
  Academy
  CoachingCenter
  OnlineCoaching

  @@map("platform_type")
}

enum PlatformApplicationFormStatus {
  pending
  approved
  rejected

  @@map("application_status")
}

enum CourseStatus {
  draft
  published
  archived
  deleted

  @@map("course_status")
}

enum AnnouncementScope {
  platform
  course

  @@map("announcement_scope")
}

enum OrderStatus {
  pending
  completed
  failed
  refunded

  @@map("order_status")
}

// 1. Users
model User {
  id              String   @id @default(uuid()) @db.Uuid
  
  username        String   @db.VarChar(100)
  email           String   @unique @db.VarChar(255)
  password        String   @db.VarChar(255)
  role            DmanageRole @default(student) @map("dmanage_role")
  // systemRole      SystemRole @default(user) @map("system_role")
  // platformRole    PlatformRole? @default(student) @map("institute_role")
  avatarUrl       String?  @map("avatar_url")
  isEmailVerified Boolean  @default(false) @map("is_email_verified")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // relations
  createdPlatforms          Platform[]
  platformApplications      PlatformApplicationsForm[] @relation("Applicant")
  reviewedPlatformApplications PlatformApplicationsForm[] @relation("Reviewer")
  platformMemberships       PlatformMembership[]
  courseEnrollments         CourseEnrollment[]
  lessonProgress            LessonProgress[]
  orders                    Order[]
  announcements             Announcement[]

  @@map("users")
}

// 2. platforms
model Platform {
  id          String   @id @default(uuid()) @db.Uuid
  // membershipId String   @map("membership_id") @db.Uuid

  name        String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(200)
  description String?
  logoUrl     String?  @map("logo_url")
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  creator     User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  // membership   PlatformMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  memberships   PlatformMembership[]
  courses       Course[]
  announcements Announcement[]
  approvedApplications PlatformApplicationsForm[]

  // @@unique(membershipId, name: "uq_platform_membership")
  @@map("platform")
}

// 3. Platform applications form
model PlatformApplicationsForm {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid

  name          String   @map("name") @db.VarChar(200)
  email         String   @map("email") @db.VarChar(255)
  phone         String   @map("phone") @db.VarChar(20)
  address       String?  @map("address") @db.VarChar(255)
  panNumber     String?  @map("pan_number") @db.VarChar(20)
  vatNumber     String?  @map("vat_number") @db.VarChar(20)
  role          DmanageRole @map("dmanage_role")

  status        PlatformApplicationFormStatus @default(pending)
  rejectionReason String? @map("rejection_reason")
  reviewedBy    String?  @map("reviewed_by") @db.Uuid
  approvedPlatformId String? @map("approved_platform_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user          User     @relation("Applicant", fields: [userId], references: [id], onDelete: Cascade)
  reviewer      User?    @relation("Reviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  approvedPlatform Platform? @relation(fields: [approvedPlatformId], references: [id], onDelete: SetNull)

  @@index([userId], name: "idx_inst_app_user")
  @@map("platform_application_form")
}

// 4. Platform memberships
model PlatformMembership {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  platformId  String      @map("platform_id") @db.Uuid

  role        DmanageRole @map("dmanage_role")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform   Platform   @relation(fields: [platformId], references: [id], onDelete: Cascade)
  
  courseTeachers CourseTeacher[]

  @@unique([userId, platformId], name: "uq_membership_user_platform")
  @@index([platformId], name: "idx_membership_platform")
  @@map("platform_memberships")
}

enum CourseLevel {
  beginner
  intermediate
  advanced

  @@map("course_level")
}

// 5. Courses
model Course {
  id           String   @id @default(uuid()) @db.Uuid
  platformId  String   @map("platform_id") @db.Uuid

  title        String   @db.VarChar(300)
  description  String?
  slug        String   @db.VarChar(300) @unique
  thumbnailUrl String?  @map("thumbnail_url")
  preview_video_url String?  @map("preview_video_url")
  difficulty_level  CourseLevel @default(beginner)
  total_duration_seconds Int?     @map("total_duration_seconds")
  is_free       Boolean  @default(false) @map("is_free")
  price        Decimal  @default(0) @db.Decimal(10,2)
  status       CourseStatus @default(draft)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  platform    Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  teachers            CourseTeacher[]
  enrollments         CourseEnrollment[]
  chapters            CourseChapter[]
  liveClasses         LiveClass[]
  announcementTargets AnnouncementTarget[]
  orders              Order[]

  @@index([platformId], name: "idx_course_platform")
  @@map("courses")
}

// 6. Course teachers
model CourseTeacher {
  id           String   @id @default(uuid()) @db.Uuid
  courseId     String   @map("course_id") @db.Uuid
  membershipId String   @map("membership_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  course       Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  membership   PlatformMembership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([courseId, membershipId], name: "uq_course_teacher")
  @@map("course_teachers")
}

// 7. Course enrollments
model CourseEnrollment {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  enrolledAt DateTime @default(now()) @map("enrolled_at") @db.Timestamptz

  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId], name: "uq_course_enrollment")
  @@map("course_enrollments")
}

// 8. Course chapters
model CourseChapter {
  id         String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid

  title      String   @db.VarChar(300)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  course     Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons    CourseLesson[]

  @@index([courseId], name: "idx_chapter_course")
  @@map("course_chapters")
}

// 9. Course lessons
model CourseLesson {
  id              String   @id @default(uuid()) @db.Uuid
  chapterId       String   @map("chapter_id") @db.Uuid
  title           String   @db.VarChar(300)
  contentType     String   @default("video") @map("content_type") @db.VarChar(50)
  contentUrl      String?  @map("content_url")
  durationSeconds Int?     @map("duration_seconds")
  sortOrder       Int      @default(0) @map("sort_order")
  isFree          Boolean  @default(false) @map("is_free")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  chapter         CourseChapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  progress        LessonProgress[]

  @@index([chapterId], name: "idx_lesson_chapter")
  @@map("course_lessons")
}

// 10. Live classes
model LiveClass {
  id              String   @id @default(uuid()) @db.Uuid
  courseId        String   @map("course_id") @db.Uuid
  title           String   @db.VarChar(300)
  description     String?
  meetingUrl      String?  @map("meeting_url")
  scheduledAt     DateTime @map("scheduled_at") @db.Timestamptz
  durationMinutes Int?     @map("duration_minutes")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId], name: "idx_live_class_course")
  @@map("live_classes")
}

// 11. Announcements
model Announcement {
  id          String   @id @default(uuid()) @db.Uuid
  platformId String   @map("platform_id") @db.Uuid
  title       String   @db.VarChar(300)
  body        String?
  scope       AnnouncementScope @default(platform)
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  platform   Platform            @relation(fields: [platformId], references: [id], onDelete: Cascade)
  author      User                 @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  targets     AnnouncementTarget[]

  @@index([platformId], name: "idx_announcement_platform")
  @@map("announcements")
}

// 12. Announcement targets
model AnnouncementTarget {
  id             String   @id @default(uuid()) @db.Uuid
  announcementId String   @map("announcement_id") @db.Uuid
  courseId       String?  @map("course_id") @db.Uuid

  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  course         Course?      @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([announcementId], name: "idx_ann_target_announcement")
  @@map("announcement_targets")
}

// 13. Lesson progress
model LessonProgress {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  lessonId        String   @map("lesson_id") @db.Uuid
  isCompleted     Boolean  @default(false) @map("is_completed")
  progressPercent Int      @default(0) @map("progress_percent")
  completedAt     DateTime? @map("completed_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson          CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId], name: "uq_lesson_progress_user_lesson")
  @@map("lesson_progress")
}

// 14. Orders
model Order {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  courseId        String   @map("course_id") @db.Uuid
  amount          Decimal  @db.Decimal(10,2)
  currency        String   @default("USD") @db.VarChar(10)
  status          OrderStatus @default(pending)
  paymentProvider String?  @map("payment_provider") @db.VarChar(50)
  paymentId       String?  @map("payment_id") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_order_user")
  @@index([courseId], name: "idx_order_course")
  @@map("orders")
}
